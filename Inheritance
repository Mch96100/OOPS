//Hierarchical Inheritance : process by which one class acquires the properties and behaviours of more than one class

class Human{
    protected:
    string name;
};  

class Student : public Human{
    int roll_no;

    public:
    Student(string n , int r){
        name = n;
        roll_no = r;
    }
};

class People :public Human{
    int age;

    public:
    People(string n , int a){
        name = n;
        age = a;
    }

    void display(){
        cout<<"Name: "<<name<<endl;
        cout<<"Age : "<<age << endl;
    }

};

int main (){
    People obj = People("Muskan",20);
